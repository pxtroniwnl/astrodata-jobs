{
  "version": 2,
  "builds": [
    {
      "src": "dashboard/**",
      "use": "@vercel/static"
    }
  ],
  "outputDirectory": "dashboard",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://astrodata-jobs-production.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/$1"
    }
  ]
}
